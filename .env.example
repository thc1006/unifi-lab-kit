# mllab-network — Environment variable template
#
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# .env is listed in .gitignore and MUST NEVER be committed.
# For extra safety, you may keep a signed/encrypted copy of .env in _secrets/.

# ---------------------------------------------------------------------------
# WAN (public side)
# Example values use RFC 5737 TEST-NET-3 (203.0.113.0/24). Replace with your
# real public subnet / static IP assigned by your ISP or university IT.
# ---------------------------------------------------------------------------
WAN_IP=203.0.113.10
# Optional secondary WAN IP (alias) — used for services that need their own public IP
WAN_IP_ALIAS=203.0.113.11
WAN_GATEWAY=203.0.113.1
WAN_NETMASK=255.255.255.0

# ---------------------------------------------------------------------------
# LAN (internal)
# ---------------------------------------------------------------------------
LAN_SUBNET=192.168.1.0/24
LAN_GATEWAY=192.168.1.1
DNS_PRIMARY=1.1.1.1
DNS_SECONDARY=8.8.8.8

# ---------------------------------------------------------------------------
# USG Router — UniFi Security Gateway 3P, EdgeOS CLI
# ---------------------------------------------------------------------------
USG_IP=192.168.1.1
USG_USER=admin
USG_PASS=REPLACE_ME_USG_PASSWORD
# USG MAC is needed for Controller adopt/force-provision API calls
USG_MAC=aa:bb:cc:dd:ee:ff

# ---------------------------------------------------------------------------
# UniFi Network Controller — runs as Docker container on NAS
# ---------------------------------------------------------------------------
CONTROLLER_HOST=192.168.1.129
CONTROLLER_HTTPS_PORT=8443
CONTROLLER_INFORM_PORT=8080
CONTROLLER_USER=admin
CONTROLLER_PASS=REPLACE_ME_CONTROLLER_PASSWORD
# Docker container name on NAS (used with `docker exec <name> curl …`)
CONTROLLER_DOCKER_NAME=unifi

# ---------------------------------------------------------------------------
# NAS (where Controller + Samba + Docker services live)
# ---------------------------------------------------------------------------
NAS_IP=192.168.1.129
# NAS admin account (has sudo / Docker access)
NAS_USER=admin
NAS_PASS=REPLACE_ME_NAS_PASSWORD

# ---------------------------------------------------------------------------
# Servers — unified credentials after provisioning
# ---------------------------------------------------------------------------
# Some servers use one username, some another, depending on who originally
# built them. Tooling tries both.
SERVER_PRIMARY_USER=admin
SERVER_SECONDARY_USER=ops
SERVER_PASS=REPLACE_ME_SERVER_PASSWORD

# ---------------------------------------------------------------------------
# Admin SSH public key — deployed to every server's authorized_keys
# ---------------------------------------------------------------------------
ADMIN_SSH_PUBKEY=ssh-ed25519 AAAAC3Nz... admin@example.com

# ---------------------------------------------------------------------------
# Samba shares (NAS native Samba)
# ---------------------------------------------------------------------------
SAMBA_WORKGROUP=MLLAB
SAMBA_NETBIOS=MLLAB-NAS
# Comma-separated hosts allow pattern, e.g. "192.168.1.0/24"
SAMBA_HOSTS_ALLOW=192.168.1.0/24
